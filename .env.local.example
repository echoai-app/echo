# Echo environment template — copy to .env.local and fill in.
# Echo reuses the Mnemos engine's providers. At least ONE LLM key is required.
# Provider priority: GROQ > GEMINI > ANTHROPIC.

# LLM provider (pick one; Groq is free at console.groq.com)
GROQ_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Embeddings (semantic recall). Free key at voyageai.com. Optional —
# recall degrades gracefully to profile/decision memory without it.
VOYAGE_API_KEY=

# Walrus (decentralized memory storage) — testnet defaults are fine.
WALRUS_NETWORK=testnet
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sui on-chain MemoryRegistry — the wallet-signed pointer to your latest Walrus
# memory index. Deploy move/memory_registry (see move/README.md) and paste the
# package id here. Leave empty to run Walrus-only (no on-chain pointer).
NEXT_PUBLIC_ECHO_PACKAGE_ID=
NEXT_PUBLIC_SUI_NETWORK=testnet
